# Puerto del host para el simulador PSE.
PSE_SIM_PORT=8099
# Webhook del payment-service en el host (vía host.docker.internal desde el contenedor).
WEBHOOK_URL=http://host.docker.internal:8084/webhooks/fake_pse
# Base pública del simulador (a la que se redirige el navegador del usuario).
SELF_BASE_URL=http://localhost:8099
