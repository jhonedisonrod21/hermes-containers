# MinIO local (almacén S3-compatible para anexos de archivo de las citas).
# Copia a .env. SOLO para desarrollo local: en AWS se usa S3 con credenciales/rol reales.
MINIO_ROOT_USER=hermes_minio
MINIO_ROOT_PASSWORD=hermes_minio_local
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101
MINIO_REQUIREMENT_FILES_BUCKET=hermes-requirement-files
